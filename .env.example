# Database — Neon (aws-eu-central-1 / Frankfurt recommended)
DATABASE_URL=REPLACE_ME

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME

# AI — openrouter.ai (optional; demo mode runs without it)
OPENROUTER_API_KEY=REPLACE_ME

# Stripe
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_PRICE_ID=REPLACE_ME              # price_xxx for Pro ($15/mo)
STRIPE_BUSINESS_PRICE_ID=REPLACE_ME    # price_xxx for Business ($49/mo)
STRIPE_WEBHOOK_SECRET=REPLACE_ME       # whsec_xxx from Stripe CLI or webhook endpoint

# Optional — enables web search tool for agents
SERPER_API_KEY=REPLACE_ME

# App URL (for Stripe redirect and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3005

# Email — Resend (resend.com). Verify your domain in the Resend dashboard first.
RESEND_API_KEY=REPLACE_ME
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Voice — Vapi (vapi.ai). Run migrations/007_voice.sql first.
VAPI_API_KEY=REPLACE_ME
VAPI_WEBHOOK_SECRET=REPLACE_ME   # generate with: openssl rand -hex 32

# Cron — protects /api/cron/* routes
CRON_SECRET=REPLACE_ME
